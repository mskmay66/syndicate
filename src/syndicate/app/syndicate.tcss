Header {
    height: 7; /* Increase height */
    background: $boost;
    color: yellow;
}

Button {
    background: yellow;
    margin: 0 10;
    align: center middle;
}

HorizontalGroup {
    width: auto;     /* IMPORTANT */
}

#login {
    width: 100%;
    height: 100%;
    align: center middle;
}

#login > Vertical {
    width: auto;
    height: auto;
    align-horizontal: center;
}

#login_title {
    text-align: center;
    margin-bottom: 2;
    color: $text;
}
